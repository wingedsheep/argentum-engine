# Argentum Engine - Local Development Environment
# Copy this file to .env: just init
# These variables are loaded by `just server`

# =============================================================================
# Redis Configuration
# =============================================================================
# Enable Redis for session persistence (games survive server restarts)
CACHE_REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_MINUTES=1440

# =============================================================================
# Postgres Configuration (auth + stats)
# =============================================================================
# Start the dev Postgres with: docker compose -f docker-compose.local.yml up -d postgres
# The server runs Flyway migrations on startup; no manual schema setup needed.
POSTGRES_PORT=5432
POSTGRES_DB=argentum
POSTGRES_USER=argentum
POSTGRES_PASSWORD=argentum
# JDBC URL the backend uses to connect (override if you point at a different host).
DB_URL=jdbc:postgresql://localhost:5432/argentum
DB_USER=argentum
DB_PASSWORD=argentum

# =============================================================================
# Server Configuration
# =============================================================================
# Enable development endpoints (Swagger UI, debug routes)
# WARNING: Never enable in production!
GAME_DEV_ENDPOINTS_ENABLED=true

# =============================================================================
# Admin Configuration
# =============================================================================
# Password for the admin game replay feature (GET /api/admin/games)
# Access the replay UI at http://localhost:5173/admin
GAME_ADMIN_PASSWORD=admin

# =============================================================================
# Set Configuration
# =============================================================================
# Enable incomplete/development sets locally
GAME_SETS_DOMINARIA_ENABLED=true

# =============================================================================
# AI Opponent Configuration
# =============================================================================
# Enable the AI opponent feature
# Local dev defaults to Ollama (just ollama-up && just ollama-pull qwen3.6-plus)
GAME_AI_ENABLED=false

# LLM provider base URL (any OpenAI-compatible API: OpenRouter, Ollama, LiteLLM, vLLM, etc.)
# Default: http://localhost:11434/v1 (Ollama)
# GAME_AI_BASE_URL=https://openrouter.ai/api/v1        # OpenRouter
# GAME_AI_BASE_URL=http://host.docker.internal:11434/v1 # Ollama from Docker

# API key for the LLM provider (default: "ollama" — Ollama ignores it)
# GAME_AI_API_KEY=sk-or-xxxx                            # OpenRouter

# Model to use for AI gameplay decisions (default: qwen3.6-plus for Ollama)
# GAME_AI_MODEL=nvidia/nemotron-3-super-120b-a12b              # OpenRouter format
# Model to use for AI deckbuilding (defaults to GAME_AI_MODEL if not set)
# GAME_AI_DECKBUILDING_MODEL=nvidia/nemotron-3-super-120b-a12b
