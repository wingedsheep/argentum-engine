        "rulings": [
            {
                "date": "2025-11-17",
                "text": "If a creature has +1/+1 counters and -1/-1 counters on it, state-based actions remove the same number of each so that it has only one kind of those counters on it. A creature's persist ability can bring it back again if its -1/-1 counters are removed this way."
            },
            {
                "date": "2025-11-17",
                "text": "If the target creature dies but that card leaves the graveyard before the persist ability resolves, it won't be returned to the battlefield."
            },
            {
                "date": "2025-11-17",
                "text": "If a creature with persist that has +1/+1 counters on it receives enough -1/-1 counters to cause it to be destroyed by lethal damage or put into its owner's graveyard for having 0 or less toughness, persist won't trigger and the card won't return to the battlefield. That's because persist checks the creature as it last existed on the battlefield, and it still had -1/-1 counters on it at that point."
            }
        ]
    },
    "colorIdentityOverride": [
        "WHITE"
    ]
}

