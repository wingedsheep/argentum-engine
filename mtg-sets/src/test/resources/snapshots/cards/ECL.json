        "imageUri": "https://cards.scryfall.io/normal/front/f/2/f29ce8f9-42a3-43fa-8197-666cc26e2c76.jpg?1767732596",
        "rulings": [
            {
                "date": "2025-11-17",
                "text": "You can choose not to have Omni-Changeling enter as a copy of another creature. If you do, it will just be a 0/0 Shapeshifter with changeling, and unless another effect is increasing its toughness, it will be put into its owner's graveyard."
            },
            {
                "date": "2025-11-17",
                "text": "Omni-Changeling copies exactly what was printed on the original creature and nothing else, with the listed exception. It doesn't copy whether that creature is tapped or untapped, whether it has any counters on it or Auras and Equipment attached to it, or any non-copy effects that have changed its power, toughness, types, color, and so on."
            },
            {
                "date": "2025-11-17",
                "text": "If the copied creature is a token, Omni-Changeling copies the original characteristics of that token as stated by the effect that created that token, with the listed exception."
            },
            {
                "date": "2025-11-17",
                "text": "If the copied creature has {X} in its mana cost, X is 0."
            },
            {
                "date": "2025-11-17",
                "text": "If the copied creature is copying something else, then Omni-Changeling enters as whatever that creature copied, with the listed exception."
            },
            {
                "date": "2025-11-17",
                "text": "Any \"enters\" abilities of the copied creature will trigger when Omni-Changeling enters. Any \"as this creature enters\" or \"this creature enters with\" abilities of the copied creature will also work."
            }
        ]
    },
    "colorIdentityOverride": [
        "BLUE"
    ]
}

