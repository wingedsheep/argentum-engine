            }
        ],
        "staticAbilities": [
            "SuppressHexproofForGroup",
            "SuppressWardForGroup"
        ]
    },
    "metadata": {
        "collectorNumber": "111",
        "rarity": "UNCOMMON",
        "artist": "Jodie Muir",
        "imageUri": "https://cards.scryfall.io/normal/front/f/e/fee60e9d-9ee7-444a-88f3-c1929e1888fb.jpg?1726286262",
        "rulings": [
            {
                "date": "2024-09-20",
                "text": "If a spell or ability you control targets a creature an opponent controls with hexproof and Nowhere to Run leaves the battlefield while that spell or ability is on the stack, that creature becomes an illegal target for that spell or ability. This includes Nowhere to Run's own triggered ability."
            },
            {
                "date": "2024-09-20",
                "text": "If a spell or ability targeting a creature an opponent controls with a ward ability is on the stack, causing Nowhere to Run to leave the battlefield won't cause that ward ability to trigger."
            },
            {
                "date": "2024-09-20",
                "text": "Ward abilities of creatures your opponents control won't trigger as long as Nowhere to Run is on the battlefield. It doesn't matter whether or not they have hexproof."
            }
        ]
    },
    "colorIdentityOverride": [
        "BLACK"
    ]
}

