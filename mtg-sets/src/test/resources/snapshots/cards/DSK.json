                        "amount": -3
                    },
                    "target": {
                        "type": "BoundVariable",
                        "name": "target creature"
                    }
                },
                "targetRequirement": {
                    "type": "TargetObject",
                    "filter": {
                        "baseFilter": "creature ctrl:opponent"
                    },
