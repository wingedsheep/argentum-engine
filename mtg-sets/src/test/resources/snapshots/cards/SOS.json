// Withering Curse
{
    "name": "Withering Curse",
    "manaCost": "{1}{B}{B}",
    "typeLine": "Sorcery",
    "oracleText": "All creatures get -2/-2 until end of turn.\nInfusion — If you gained life this turn, destroy all creatures instead.",
    "script": {
        "spellEffect": {
            "type": "Gated",
            "gate": {
                "type": "Gate.WhenCondition",
                "condition": {
                    "type": "Compare",
                    "left": {
                        "type": "TurnTracking",
                        "player": "You",
                        "tracker": "LIFE_GAINED"
                    },
                    "operator": "GTE",
                    "right": {
                        "type": "Fixed",
                        "amount": 1
                    }
                }
            },
            "then": {
                "type": "ForEach",
                "space": {
                    "type": "IterationSpace.Group",
                    "filter": {
                        "baseFilter": "creature"
                    }
                },
                "body": {
                    "type": "MoveToZone",
                    "target": "Self",
                    "destination": "Graveyard",
                    "byDestruction": true
                }
            },
            "otherwise": {
                "type": "ForEach",
                "space": {
                    "type": "IterationSpace.Group",
                    "filter": {
                        "baseFilter": "creature"
                    }
                },
                "body": {
                    "type": "ModifyStats",
                    "powerModifier": {
                        "type": "Fixed",
                        "amount": -2
                    },
                    "toughnessModifier": {
                        "type": "Fixed",
                        "amount": -2
                    },
                    "target": "Self"
                }
            }
        }
    },
    "metadata": {
        "collectorNumber": "105",
        "rarity": "MYTHIC",
        "artist": "Tuan Duong Chu",
        "flavorText": "Although lumarets are small magical creatures, they can gather to eliminate larger threats.",
        "imageUri": "https://cards.scryfall.io/normal/front/5/0/50aaf618-dddb-4cbe-8231-d634b4498563.jpg"
    },
    "colorIdentityOverride": [
        "BLACK"
    ]
}

