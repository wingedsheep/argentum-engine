// Aang's Journey
{
    "name": "Aang's Journey",
    "manaCost": "{2}",
    "typeLine": "Sorcery — Lesson",
    "oracleText": "Kicker {2} (You may pay an additional {2} as you cast this spell.)\nSearch your library for a basic land card. If this spell was kicked, instead search your library for a basic land card and a Shrine card. Reveal those cards, put them into your hand, then shuffle.\nYou gain 2 life.",
    "keywordAbilities": [
        {
            "type": "Kicker",
            "manaCost": "{2}"
        }
    ],
    "script": {
        "spellEffect": {
            "type": "Composite",
            "effects": [
                {
                    "type": "Gated",
                    "gate": {
                        "type": "Gate.WhenCondition",
                        "condition": "WasKicked"
                    },
                    "then": {
                        "type": "Composite",
                        "effects": [
                            {
                                "type": "GatherCards",
                                "source": {
                                    "type": "FromZone",
                                    "zone": "Library",
                                    "filter": "basicland"
                                },
                                "storeAs": "landSearchable"
                            },
                            {
                                "type": "SelectFromCollection",
                                "from": "landSearchable",
                                "selection": {
                                    "type": "ChooseUpTo",
                                    "count": {
                                        "type": "Fixed",
                                        "amount": 1
                                    }
                                },
                                "storeSelected": "foundLand",
                                "prompt": "Search your library for a basic land card"
                            },
                            {
                                "type": "GatherCards",
                                "source": {
                                    "type": "FromZone",
                                    "zone": "Library",
                                    "filter": "Shrine"
                                },
                                "storeAs": "shrineSearchable"
                            },
                            {
                                "type": "SelectFromCollection",
                                "from": "shrineSearchable",
                                "selection": {
                                    "type": "ChooseUpTo",
                                    "count": {
                                        "type": "Fixed",
                                        "amount": 1
                                    }
                                },
                                "storeSelected": "foundShrine",
                                "prompt": "Search your library for a Shrine card"
                            },
                            {
                                "type": "MoveCollection",
                                "from": "foundLand",
                                "destination": {
                                    "type": "ToZone",
                                    "zone": "Hand"
                                },
                                "revealed": true
                            },
                            {
                                "type": "MoveCollection",
                                "from": "foundShrine",
                                "destination": {
                                    "type": "ToZone",
                                    "zone": "Hand"
                                },
                                "revealed": true
                            },
                            "ShuffleLibrary"
                        ]
                    },
                    "otherwise": {
                        "type": "Composite",
                        "effects": [
                            {
                                "type": "GatherCards",
                                "source": {
                                    "type": "FromZone",
                                    "zone": "Library",
                                    "filter": "basicland"
                                },
                                "storeAs": "searchable"
                            },
                            {
                                "type": "SelectFromCollection",
                                "from": "searchable",
                                "selection": {
                                    "type": "ChooseUpTo",
                                    "count": {
                                        "type": "Fixed",
                                        "amount": 1
                                    }
                                },
                                "storeSelected": "found"
                            },
                            {
                                "type": "MoveCollection",
                                "from": "found",
                                "destination": {
                                    "type": "ToZone",
                                    "zone": "Hand"
                                },
                                "revealed": true
                            },
                            "ShuffleLibrary"
                        ]
                    }
                },
                {
                    "type": "GainLife",
                    "amount": {
                        "type": "Fixed",
                        "amount": 2
                    }
                }
            ]
        }
    },
    "metadata": {
        "collectorNumber": "1",
        "artist": "Kotakan",
        "imageUri": "https://cards.scryfall.io/normal/front/5/e/5e51f727-5a9b-4bc7-83a9-dbcf1c933e15.jpg?1778833139"
