        "rulings": [
            {
                "date": "2025-07-25",
                "text": "The cost of the activated ability granted by The Dominion Bracelet is locked in before costs are paid. For example, if the power of the equipped creature is 3 (including the +1/+1 granted by The Dominion Bracelet's ability), the granted ability will cost {12} to activate."
