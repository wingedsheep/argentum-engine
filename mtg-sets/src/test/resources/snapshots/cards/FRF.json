                                "zone": "Exile"
                            }
                        },
                        {
                            "type": "GrantMayPlayFromExile",
                            "from": "exiledCard"
                        }
                    ]
                },
                "triggerCondition": {
                    "type": "SourceChosenModeIs",
                    "modeId": "khans"
                }
            },
            {
                "id": "ability_2",
                "trigger": {
                    "type": "ZoneChangeEvent",
