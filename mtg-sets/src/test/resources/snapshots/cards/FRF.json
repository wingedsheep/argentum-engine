                    },
                    "target": {
                        "type": "BoundVariable",
                        "name": "target"
                    }
                },
                "targetRequirement": {
                    "type": "AnyTarget",
                    "id": "target"
                },
                "triggerCondition": {
                    "type": "SourceChosenModeIs",
                    "modeId": "dragons"
                }
            }
        ],
        "replacementEffects": [
            {
                "type": "EntersWithChoice",
                "choiceType": "MODE",
                "modeOptions": [
                    {
                        "id": "khans",
                        "label": "Khans",
                        "description": "At your upkeep, exile the top card of your library; you may play it this turn.",
                        "iconKey": "khans"
                    },
                    {
                        "id": "dragons",
