// Macabre Waltz
{
    "name": "Macabre Waltz",
    "manaCost": "{1}{B}",
    "typeLine": "Sorcery",
    "oracleText": "Return up to two target creature cards from your graveyard to your hand, then discard a card.",
    "script": {
        "spellEffect": {
            "type": "Composite",
            "effects": [
                {
                    "type": "ForEach",
                    "space": "IterationSpace.Targets",
                    "body": {
                        "type": "MoveToZone",
                        "target": {
                            "type": "ContextTarget",
                            "index": 0
                        },
                        "destination": "Hand"
                    }
                },
                {
                    "type": "Composite",
                    "effects": [
                        {
                            "type": "GatherCards",
                            "source": {
                                "type": "FromZone",
                                "zone": "Hand"
                            },
                            "storeAs": "hand"
                        },
                        {
                            "type": "SelectFromCollection",
                            "from": "hand",
                            "selection": {
                                "type": "ChooseExactly",
                                "count": {
                                    "type": "Fixed",
                                    "amount": 1
                                }
                            },
                            "storeSelected": "discarded",
                            "prompt": "Choose 1 card to discard"
                        },
                        {
                            "type": "MoveCollection",
                            "from": "discarded",
                            "destination": {
                                "type": "ToZone",
                                "zone": "Graveyard"
                            },
                            "moveType": "Discard"
                        }
                    ]
                }
            ]
        },
        "targetRequirements": [
            {
                "type": "TargetObject",
                "count": 2,
                "optional": true,
                "filter": {
                    "baseFilter": "creature own:you",
                    "zone": "Graveyard"
                },
                "id": "target"
            }
        ]
    },
    "metadata": {
        "collectorNumber": "47",
        "artist": "Jim Murray",
        "flavorText": "\"All dead move to the hollow rhythm of necromancy.\"\n—Savra",
        "imageUri": "https://cards.scryfall.io/normal/front/d/9/d9cd7bc3-73ba-4364-84b2-9954648cd8a9.jpg"
    },
    "colorIdentityOverride": [
        "BLACK"
    ]
}

