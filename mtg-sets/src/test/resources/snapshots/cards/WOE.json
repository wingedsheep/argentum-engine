// Break the Spell
{
    "name": "Break the Spell",
    "manaCost": "{W}",
    "typeLine": "Instant",
    "oracleText": "Destroy target enchantment. If a permanent you controlled or a token was destroyed this way, draw a card.",
    "script": {
        "spellEffect": {
            "type": "Composite",
            "effects": [
                {
                    "type": "GatherCards",
                    "source": "ChosenTargets",
