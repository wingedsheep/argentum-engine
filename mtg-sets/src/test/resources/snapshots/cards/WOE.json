        "triggeredAbilities": [
            {
                "id": "ability_1",
                "trigger": {
                    "type": "StepEvent",
                    "step": "BEGIN_COMBAT"
                },
                "binding": "ANY",
                "effect": {
                    "type": "Gated",
                    "gate": {
                        "type": "Gate.MayPay",
                        "cost": {
                            "type": "PayManaCost",
                            "cost": "{1}"
                        }
                    },
                    "then": {
                        "type": "CreateRoleToken",
                        "roleName": "Sorcerer Role",
                        "target": {
                            "type": "BoundVariable",
                            "name": "target creature you control"
                        }
                    }
                },
                "targetRequirement": {
                    "type": "TargetObject",
                    "filter": {
                        "baseFilter": "creature ctrl:you"
                    },
                    "id": "target creature you control"
                }
            }
        ]
    },
    "metadata": {
        "collectorNumber": "31",
        "rarity": "RARE",
        "artist": "Scott Murphy",
        "imageUri": "https://cards.scryfall.io/normal/front/4/c/4ceac5b5-05eb-4f00-9477-3db490be24dd.jpg?1692936729",
        "rulings": [
            {
                "date": "2023-09-01",
                "text": "You don't choose a target for Spellbook Vendor's ability at the time it triggers. Rather, a second reflexive ability triggers when you pay this way. You choose a target for that ability as it goes on the stack."
            },
            {
                "date": "2023-09-01",
                "text": "Roles are colorless enchantment tokens. Each one has the Aura and Role subtypes and the enchant creature ability."
            }
        ]
    },
    "colorIdentityOverride": [
        "WHITE"
    ]
}

