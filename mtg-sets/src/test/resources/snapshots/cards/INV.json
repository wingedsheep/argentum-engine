                            },
                            "moveType": "Discard"
                        },
                        {
                            "type": "Gated",
                            "gate": {
                                "type": "Gate.WhenCondition",
                                "condition": {
                                    "type": "CollectionContainsMatch",
                                    "collection": "discarded",
                                    "filter": "creature"
