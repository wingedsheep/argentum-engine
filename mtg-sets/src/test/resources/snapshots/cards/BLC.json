// Simic Ascendancy
{
    "name": "Simic Ascendancy",
    "manaCost": "{G}{U}",
    "typeLine": "Enchantment",
    "oracleText": "{1}{G}{U}: Put a +1/+1 counter on target creature you control.\nWhenever one or more +1/+1 counters are put on a creature you control, put that many growth counters on Simic Ascendancy.\nAt the beginning of your upkeep, if Simic Ascendancy has twenty or more growth counters on it, you win the game.",
    "script": {
        "triggeredAbilities": [
