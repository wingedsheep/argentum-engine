// Blue Sun's Twilight
{
    "name": "Blue Sun's Twilight",
    "manaCost": "{X}{U}{U}",
    "typeLine": "Sorcery",
    "oracleText": "Gain control of target creature with mana value X or less. If X is 5 or more, create a token that's a copy of that creature.",
    "script": {
        "spellEffect": {
            "type": "Composite",
            "effects": [
                {
                    "type": "GainControl",
                    "target": {
                        "type": "BoundVariable",
                        "name": "creature"
                    }
                },
                {
                    "type": "Gated",
                    "gate": {
                        "type": "Gate.WhenCondition",
                        "condition": {
                            "type": "Compare",
                            "left": "XValue",
                            "operator": "GTE",
                            "right": {
                                "type": "Fixed",
                                "amount": 5
                            }
                        }
                    },
                    "then": {
                        "type": "CreateTokenCopyOfTarget",
                        "target": {
                            "type": "BoundVariable",
                            "name": "creature"
                        }
                    }
                }
            ]
        },
        "targetRequirements": [
            {
                "type": "TargetObject",
                "filter": {
                    "baseFilter": {
                        "cardPredicates": [
                            "IsCreature",
                            "ManaValueAtMostX"
                        ]
                    }
                },
                "id": "creature"
            }
        ]
    },
    "metadata": {
        "collectorNumber": "43",
        "rarity": "RARE",
        "artist": "Piotr Dura",
        "flavorText": "\"Where once there was ignorance, Jin-Gitaxias brought knowledge, and an age of progress dawned.\"\n—Monument inscription",
        "imageUri": "https://cards.scryfall.io/normal/front/3/a/3a836e6b-6854-4f6f-bc78-2da1fd4dd224.jpg?1675956948",
        "rulings": [
            {
                "date": "2023-02-04",
                "text": "If the target creature is an illegal target by the time the spell tries to resolve, the spell will not resolve. No token is created, even if X is 5 or more."
            }
        ]
    },
    "colorIdentityOverride": [
        "BLUE"
    ]
}

